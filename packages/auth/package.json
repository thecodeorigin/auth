{
  "name": "@thecodeorigin/auth",
  "type": "module",
  "version": "0.0.1",
  "private": false,
  "description": "THECODEORIGIN Authentication Portal client module",
  "repository": "https://github.com/thecodeorigin/auth",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./contract": {
      "types": "./dist/contract/index.d.mts",
      "import": "./dist/contract/index.mjs"
    },
    "./server": {
      "types": "./dist/runtime/server/index.d.ts",
      "import": "./dist/runtime/server/index.js"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "contract": [
        "./dist/contract/index.d.mts"
      ],
      "server": [
        "./dist/runtime/server/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@casl/ability": "catalog:",
    "@casl/vue": "catalog:",
    "@nuxt/kit": "catalog:",
    "defu": "catalog:",
    "h3": "catalog:",
    "ofetch": "catalog:",
    "ufo": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nuxt/devtools": "catalog:",
    "@nuxt/eslint-config": "catalog:",
    "@nuxt/module-builder": "catalog:",
    "@nuxt/schema": "catalog:",
    "@nuxt/test-utils": "catalog:",
    "@types/node": "catalog:",
    "changelogen": "catalog:",
    "eslint": "catalog:",
    "nuxt": "catalog:",
    "typescript": "catalog:",
    "unbuild": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  }
}
