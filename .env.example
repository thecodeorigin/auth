NUXT_PUBLIC_SITE_URL=http://localhost:3000

NUXT_RESEND_API_KEY=
NUXT_EMAIL_FROM=auth@thecodeorigin.com

NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=
NUXT_GITHUB_CLIENT_ID=
NUXT_GITHUB_CLIENT_SECRET=

NUXT_ADMIN_USER_IDS=
NUXT_SEED_ADMIN_EMAIL=admin@thecodeorigin.com
NUXT_ALLOW_IMPERSONATION=

# Polar (sandbox) — https://sandbox.polar.sh
# Products are resolved from the Polar API at runtime and matched to the catalog
# by NAME (name your Polar products to match shared/catalog.ts plan names, e.g.
# "NordPass Premium", "NordVPN Complete"). No product IDs in env.
# NUXT_POLAR_WEBHOOK_SECRET is auto-provisioned in dev (ngrok); set it only in prod.
NUXT_POLAR_ACCESS_TOKEN=
NUXT_POLAR_WEBHOOK_SECRET=

NUXT_NGROK_AUTHTOKEN=
# Dev/CI-only demo mode: enables "sign in as agent" (/api/_agent/sign-in) + relaxes
# Polar customer creation for test email domains. NEVER set in production.
NUXT_DEMO_MODE=
